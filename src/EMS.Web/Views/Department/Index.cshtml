@model IEnumerable<EMS.Application.DTOs.Department.DepartmentDto>
@{
    ViewData["Title"] = "Departments";
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold text-dark m-0">Departments</h2>
        <p class="text-muted m-0">Manage organizational units and department managers</p>
    </div>
    @if (User.IsInRole("Admin") || User.IsInRole("HR"))
    {
        <a asp-action="Create" class="btn btn-brand">
            <i class="bi bi-plus-lg me-2"></i>New Department
        </a>
    }
</div>

<div class="card wfh-card overflow-hidden">
    <div class="card-body p-0">
        @if (Model == null || !Model.Any())
        {
            ViewData["EmptyStateIcon"] = "bi-building";
            ViewData["EmptyStateHeading"] = "No Departments Found";
            ViewData["EmptyStateSubtext"] = "Get started by creating a new department above.";
            ViewData["EmptyStateActionUrl"] = Url.Action("Create");
            ViewData["EmptyStateActionText"] = "New Department";
            ViewData["EmptyStateActionRole"] = "Admin";
            <partial name="_EmptyState" />
        }
        else
        {
            <div class="table-responsive">
                <table class="wfh-table">
                    <caption class="visually-hidden">List of departments including department code, name, manager, employee count, and action links</caption>
                    <thead>
                        <tr>
                            <th scope="col" class="ps-4">Code</th>
                            <th scope="col">Department Name</th>
                            <th scope="col">Manager</th>
                            <th scope="col" class="text-center">Employees</th>
                            <th scope="col" class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <span class="wfh-badge wfh-badge--resigned">@item.Code</span>
                                </td>
                                <td class="fw-semibold text-dark">@item.Name</td>
                                <td class="text-muted">@(item.ManagerFullName ?? "No Manager Assigned")</td>
                                <td class="text-center">
                                    <span class="badge bg-info-subtle text-info rounded-pill px-3 py-1" style="font-size: 0.85rem;">@item.TotalEmployees</span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" title="Details" aria-label="View details for department @item.Name">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (User.IsInRole("Admin") || User.IsInRole("HR"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Edit" aria-label="Edit department @item.Name">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <button type="button" class="btn btn-sm btn-outline-danger" 
                                                    data-bs-toggle="modal" data-bs-target="#deleteModal" 
                                                    data-action="@Url.Action("Delete", "Department", new { id = item.Id })" 
                                                    data-name="@item.Name" 
                                                    data-warning="@(item.TotalEmployees > 0 ? $"This department currently has {item.TotalEmployees} active employee(s). You must reassign or remove them before deleting this department." : null)"
                                                    title="Delete" aria-label="Delete department @item.Name">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<partial name="_DeleteModal" />
