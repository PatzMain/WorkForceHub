@model EMS.Application.DTOs.Department.DepartmentDto
@{
    ViewData["Title"] = Model.Name + " - Details";
    Layout = "_Layout";
    ViewData["Breadcrumbs"] = new List<(string Label, string? Url)>
    {
        ("Departments", Url.Action("Index", "Department")),
        (Model.Name, null)
    };
}

<div class="card wfh-card mb-4">
    <div class="card-body p-5">
        <div class="row align-items-center">
            <div class="col-md-8">
                <span class="wfh-badge wfh-badge--resigned mb-2">@Model.Code</span>
                <h2 class="fw-bold text-dark m-0">@Model.Name</h2>
                <p class="text-muted mt-2 mb-0">Created on @Model.CreatedAt.ToString("MMMM dd, yyyy")</p>
            </div>
            <div class="col-md-4 text-md-end mt-3 mt-md-0">
                @if (User.IsInRole("Admin") || User.IsInRole("HR"))
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-brand me-2">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </a>
                    <button type="button" class="btn btn-muted" 
                            data-bs-toggle="modal" data-bs-target="#deleteModal" 
                            data-action="@Url.Action("Delete", "Department", new { id = Model.Id })" 
                            data-name="@Model.Name" 
                            data-warning="@(Model.TotalEmployees > 0 ? $"This department currently has {Model.TotalEmployees} active employee(s). You must reassign or remove them before deleting this department." : null)"
                            aria-label="Delete department @Model.Name">
                        <i class="bi bi-trash me-1"></i>Delete
                    </button>
                }
            </div>
        </div>

        <hr class="my-4" />

        <div class="row">
            <div class="col-md-6 mb-4">
                <label class="form-label-custom d-block">Department Manager</label>
                <div class="fs-5 text-dark fw-semibold">@(Model.ManagerFullName ?? "No Manager Assigned")</div>
            </div>
            <div class="col-md-6 mb-4">
                <label class="form-label-custom d-block">Total Staff Members</label>
                <div class="fs-5 text-dark fw-semibold">@Model.TotalEmployees Employees</div>
            </div>
        </div>
    </div>
</div>

<partial name="_DeleteModal" />
