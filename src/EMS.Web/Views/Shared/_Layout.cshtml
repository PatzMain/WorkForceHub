<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WorkForceHub</title>
    
    <!-- Premium Fonts & Icons -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap&subset=latin" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    
    <link href="~/css/tokens.css" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet">
    
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <a href="#main-content" class="skip-link">Skip to main content</a>

    @if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <div class="app-layout">
            <partial name="_Sidebar" />
            <div class="main-content">
                <partial name="_TopHeader" />
                <main role="main" class="container-fluid px-4 py-4 flex-grow-1" id="main-content">
                    @RenderBody()
                </main>
                <footer class="footer bg-white border-top py-3 text-center text-muted small mt-auto">
                    <div class="container-fluid">
                        &copy; @DateTime.UtcNow.Year - WorkForceHub. All rights reserved.
                    </div>
                </footer>
            </div>
        </div>
    }
    else
    {
        <header class="sticky-top bg-white border-bottom shadow-sm">
            <nav class="navbar navbar-expand-lg navbar-light bg-white py-3" aria-label="Global Navigation">
                <div class="container">
                    <a class="navbar-brand fs-4" asp-controller="Home" asp-action="Index">WorkForceHub</a>
                    <div class="d-flex align-items-center gap-2">
                        <a asp-controller="Account" asp-action="Login" class="btn btn-light btn-sm px-3">Sign In</a>
                        <a asp-controller="Account" asp-action="Register" class="btn btn-brand btn-sm px-3">Register</a>
                    </div>
                </div>
            </nav>
        </header>
        <main role="main" class="container py-5 min-vh-75" id="main-content">
            @RenderBody()
        </main>
        <footer class="footer bg-white border-top py-4 text-center mt-auto text-muted small">
            <div class="container">
                &copy; @DateTime.UtcNow.Year - WorkForceHub. All rights reserved.
            </div>
        </footer>
    }

    <!-- Toast Notifications Container -->
    <div class="toast-container position-fixed bottom-0 end-0 p-3">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="toast wfh-toast wfh-toast--success" role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="4000">
                <div class="toast-header border-0 bg-transparent pb-0">
                    <strong class="me-auto text-success d-flex align-items-center gap-2">
                        <i class="bi bi-check-circle-fill"></i> Success
                    </strong>
                    <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
                <div class="toast-body pt-1 pb-3 text-dark">
                    @TempData["SuccessMessage"]
                </div>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="toast wfh-toast wfh-toast--danger" role="alert" aria-live="assertive" aria-atomic="true" data-bs-delay="4000">
                <div class="toast-header border-0 bg-transparent pb-0">
                    <strong class="me-auto text-danger d-flex align-items-center gap-2">
                        <i class="bi bi-exclamation-triangle-fill"></i> Error
                    </strong>
                    <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
                </div>
                <div class="toast-body pt-1 pb-3 text-dark">
                    @TempData["ErrorMessage"]
                </div>
            </div>
        }
    </div>

    <!-- Bootstrap Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Auto-initialize and show toasts
            const toastElList = [].slice.call(document.querySelectorAll('.toast'));
            const toastList = toastElList.map(function (toastEl) {
                const t = new bootstrap.Toast(toastEl);
                t.show();
                return t;
            });
        });
    </script>
    
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
