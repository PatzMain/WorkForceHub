@{
    ViewData["Title"] = "Page Not Found";
    Layout = "_Layout";
}

<div class="row justify-content-center align-items-center min-vh-75">
    <div class="col-md-6 text-center">
        <div class="mb-4 text-warning">
            <i class="bi bi-question-diamond" style="font-size: 4rem;"></i>
        </div>
        <h1 class="fw-bold text-dark mb-2">404 - Not Found</h1>
        <p class="text-muted mb-4">The page or resource you are looking for does not exist or has been moved.</p>

        <a href="/" class="btn btn-brand py-2.5 px-4">
            Return to Dashboard
        </a>
    </div>
</div>
