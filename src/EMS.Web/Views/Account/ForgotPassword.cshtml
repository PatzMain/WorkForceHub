@model EMS.Application.DTOs.Account.ForgotPasswordDto
@{
    ViewData["Title"] = "Forgot Password";
    Layout = "_Layout";
}

<div class="row justify-content-center align-items-center min-vh-75">
    <div class="col-md-5">
        <div class="card wfh-card overflow-hidden">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <h2 class="fw-bold text-dark m-0">Forgot Password</h2>
                    <p class="text-muted mt-2 mb-0">Enter your email to receive a password reset link</p>
                </div>

                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 mb-3" role="alert" style="border-radius: var(--radius-md);"></div>

                    <div class="form-floating mb-4">
                        <input asp-for="Email" class="form-control" placeholder="name@example.com" autocomplete="email" />
                        <label asp-for="Email">Email address</label>
                        <span asp-validation-for="Email" class="invalid-feedback-custom"></span>
                    </div>

                    <button type="submit" class="btn btn-brand w-100 py-3 fw-bold">
                        Send Reset Link
                    </button>
                </form>

                <div class="text-center mt-4">
                    <a asp-action="Login" class="text-primary text-decoration-none small fw-semibold">Back to Login</a>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
