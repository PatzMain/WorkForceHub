@model EMS.Application.DTOs.Account.ResetPasswordDto
@{
    ViewData["Title"] = "Reset Password";
    Layout = "_Layout";
}

<div class="row justify-content-center align-items-center min-vh-75">
    <div class="col-md-5">
        <div class="card wfh-card overflow-hidden">
            <div class="card-body p-5">
                <div class="text-center mb-4">
                    <h2 class="fw-bold text-dark m-0">Reset Password</h2>
                    <p class="text-muted mt-2 mb-0">Enter your details and new password below</p>
                </div>

                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 mb-3" role="alert" style="border-radius: var(--radius-md);"></div>
                    <input type="hidden" asp-for="Code" />

                    <div class="form-floating mb-3">
                        <input asp-for="Email" class="form-control" placeholder="name@example.com" autocomplete="email" />
                        <label asp-for="Email">Email address</label>
                        <span asp-validation-for="Email" class="invalid-feedback-custom"></span>
                    </div>

                    <div class="form-floating mb-3 position-relative">
                        <input asp-for="Password" class="form-control" placeholder="New Password" id="password-input" autocomplete="new-password" />
                        <label asp-for="Password">New Password</label>
                        <button type="button" class="btn position-absolute top-50 end-0 translate-middle-y me-2 border-0 bg-transparent text-muted" id="toggle-password-btn" aria-label="Show password">
                            <i class="bi bi-eye-slash" id="password-toggle-icon"></i>
                        </button>
                        <span asp-validation-for="Password" class="invalid-feedback-custom"></span>
                    </div>

                    <div class="form-floating mb-4 position-relative">
                        <input asp-for="ConfirmPassword" class="form-control" placeholder="Confirm Password" id="confirm-password-input" autocomplete="new-password" />
                        <label asp-for="ConfirmPassword">Confirm Password</label>
                        <button type="button" class="btn position-absolute top-50 end-0 translate-middle-y me-2 border-0 bg-transparent text-muted" id="toggle-confirm-password-btn" aria-label="Show confirm password">
                            <i class="bi bi-eye-slash" id="confirm-password-toggle-icon"></i>
                        </button>
                        <span asp-validation-for="ConfirmPassword" class="invalid-feedback-custom"></span>
                    </div>

                    <button type="submit" class="btn btn-brand w-100 py-3 fw-bold">
                        Reset Password
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Password toggle
            const passwordInput = document.getElementById("password-input");
            const toggleBtn = document.getElementById("toggle-password-btn");
            const toggleIcon = document.getElementById("password-toggle-icon");
            
            if (toggleBtn && passwordInput) {
                toggleBtn.addEventListener("click", function () {
                    if (passwordInput.type === "password") {
                        passwordInput.type = "text";
                        toggleIcon.className = "bi bi-eye";
                        toggleBtn.setAttribute("aria-label", "Hide password");
                    } else {
                        passwordInput.type = "password";
                        toggleIcon.className = "bi bi-eye-slash";
                        toggleBtn.setAttribute("aria-label", "Show password");
                    }
                });
            }

            // Confirm password toggle
            const confirmInput = document.getElementById("confirm-password-input");
            const toggleConfirmBtn = document.getElementById("toggle-confirm-password-btn");
            const toggleConfirmIcon = document.getElementById("confirm-password-toggle-icon");
            
            if (toggleConfirmBtn && confirmInput) {
                toggleConfirmBtn.addEventListener("click", function () {
                    if (confirmInput.type === "password") {
                        confirmInput.type = "text";
                        toggleConfirmIcon.className = "bi bi-eye";
                        toggleConfirmBtn.setAttribute("aria-label", "Hide password confirmation");
                    } else {
                        confirmInput.type = "password";
                        toggleConfirmIcon.className = "bi bi-eye-slash";
                        toggleConfirmBtn.setAttribute("aria-label", "Show password confirmation");
                    }
                });
            }
        });
    </script>
}
