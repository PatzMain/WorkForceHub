@{
    ViewData["Title"] = "Reset Password Confirmation";
    Layout = "_Layout";
}

<div class="row justify-content-center align-items-center min-vh-75">
    <div class="col-md-5">
        <div class="card wfh-card text-center p-5">
            <div class="mb-4">
                <i class="bi bi-shield-check text-success" style="font-size: 3rem;"></i>
            </div>
            <h2 class="fw-bold text-dark mb-3">Password Reset Complete</h2>
            <p class="text-muted mb-4">Your password has been successfully reset. You can now use your new password to sign in.</p>
            <a asp-action="Login" class="btn btn-brand w-100 py-3 fw-bold">
                Sign In
            </a>
        </div>
    </div>
</div>
