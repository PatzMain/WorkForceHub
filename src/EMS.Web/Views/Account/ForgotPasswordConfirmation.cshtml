@{
    ViewData["Title"] = "Forgot Password Confirmation";
    Layout = "_Layout";
}

<div class="row justify-content-center align-items-center min-vh-75">
    <div class="col-md-5">
        <div class="card wfh-card text-center p-5">
            <div class="mb-4">
                <i class="bi bi-envelope-check text-info" style="font-size: 3rem;"></i>
            </div>
            <h2 class="fw-bold text-dark mb-3">Check Your Email</h2>
            <p class="text-muted mb-4">If an account exists for that email, we have sent a password reset link to it. Please check your inbox (and spam folder).</p>
            <a asp-action="Login" class="btn btn-brand w-100 py-3 fw-bold">
                Return to Login
            </a>
        </div>
    </div>
</div>
