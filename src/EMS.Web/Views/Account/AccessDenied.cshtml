@{
    ViewData["Title"] = "Access Denied";
    Layout = "_Layout";
}

<div class="row justify-content-center align-items-center min-vh-75">
    <div class="col-md-5">
        <div class="card wfh-card text-center p-5">
            <div class="mb-4 text-danger">
                <i class="bi bi-x-octagon-fill" style="font-size: 4rem;"></i>
            </div>
            <h2 class="fw-bold text-dark mb-3">Access Denied</h2>
            <p class="text-muted mb-4">You do not have permission to view this page or perform this action. If you believe this is an error, contact your administrator.</p>
            <a href="/" class="btn btn-muted py-3 w-100">
                Back to Dashboard
            </a>
        </div>
    </div>
</div>
