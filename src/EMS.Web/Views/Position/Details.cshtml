@model EMS.Application.DTOs.Position.PositionDto
@{
    ViewData["Title"] = Model.Title + " - Details";
    Layout = "_Layout";
    ViewData["Breadcrumbs"] = new List<(string Label, string? Url)>
    {
        ("Positions", Url.Action("Index", "Position")),
        (Model.Title, null)
    };
}

<div class="card wfh-card mb-4">
    <div class="card-body p-5">
        <div class="row align-items-center">
            <div class="col-md-8">
                <span class="wfh-badge wfh-badge--resigned mb-2">Grade @Model.SalaryGrade</span>
                <h2 class="fw-bold text-dark m-0">@Model.Title</h2>
                <p class="text-muted mt-2 mb-0">Base Salary: <strong>@Model.BaseSalary.ToString("C")</strong></p>
            </div>
            <div class="col-md-4 text-md-end mt-3 mt-md-0">
                @if (User.IsInRole("Admin") || User.IsInRole("HR"))
                {
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-brand me-2">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </a>
                    <button type="button" class="btn btn-muted" 
                            data-bs-toggle="modal" data-bs-target="#deleteModal" 
                            data-action="@Url.Action("Delete", "Position", new { id = Model.Id })" 
                            data-name="@Model.Title" 
                            data-warning="@(Model.TotalEmployees > 0 ? $"This position is currently assigned to {Model.TotalEmployees} active employee(s). You must assign them to a different position before deleting this position." : null)"
                            aria-label="Delete position @Model.Title">
                        <i class="bi bi-trash me-1"></i>Delete
                    </button>
                }
            </div>
        </div>

        <hr class="my-4" />

        <div class="row">
            <div class="col-md-12 mb-4">
                <label class="form-label-custom d-block">Description</label>
                <div class="text-dark">@(string.IsNullOrEmpty(Model.Description) ? "No description provided." : Model.Description)</div>
            </div>
            <div class="col-md-6">
                <label class="form-label-custom d-block">Total Staff in this Position</label>
                <div class="fs-5 text-dark fw-semibold">@Model.TotalEmployees Employees</div>
            </div>
        </div>
    </div>
</div>

<partial name="_DeleteModal" />
