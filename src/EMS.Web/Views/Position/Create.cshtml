@model EMS.Application.DTOs.Position.PositionCreateDto
@{
    ViewData["Title"] = "New Position";
    Layout = "_Layout";
    ViewData["Breadcrumbs"] = new List<(string Label, string? Url)>
    {
        ("Positions", Url.Action("Index", "Position")),
        ("New Position", null)
    };
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card wfh-card">
            <div class="card-body p-5">
                <h3 class="fw-bold text-dark mb-4">Create Position</h3>

                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0" role="alert" style="border-radius: var(--radius-md);"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label-custom">Position Title</label>
                        <input asp-for="Title" class="form-control @(ViewData.ModelState.GetFieldValidationState("Title") == Microsoft.AspNetCore.Mvc.ModelBinding.ModelValidationState.Invalid ? "is-invalid" : "")" placeholder="e.g. Senior Software Engineer" aria-describedby="Title-error" />
                        <span id="Title-error" asp-validation-for="Title" class="invalid-feedback-custom"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label-custom">Description</label>
                        <textarea asp-for="Description" class="form-control @(ViewData.ModelState.GetFieldValidationState("Description") == Microsoft.AspNetCore.Mvc.ModelBinding.ModelValidationState.Invalid ? "is-invalid" : "")" rows="3" placeholder="Provide a brief description of duties and responsibilities..." aria-describedby="Description-error"></textarea>
                        <span id="Description-error" asp-validation-for="Description" class="invalid-feedback-custom"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="BaseSalary" class="form-label-custom">Base Salary</label>
                            <input asp-for="BaseSalary" type="number" step="0.01" class="form-control @(ViewData.ModelState.GetFieldValidationState("BaseSalary") == Microsoft.AspNetCore.Mvc.ModelBinding.ModelValidationState.Invalid ? "is-invalid" : "")" placeholder="e.g. 5000" aria-describedby="BaseSalary-error" />
                            <span id="BaseSalary-error" asp-validation-for="BaseSalary" class="invalid-feedback-custom"></span>
                        </div>
                        <div class="col-md-6 mb-4">
                            <label asp-for="SalaryGrade" class="form-label-custom">Salary Grade</label>
                            <input asp-for="SalaryGrade" class="form-control @(ViewData.ModelState.GetFieldValidationState("SalaryGrade") == Microsoft.AspNetCore.Mvc.ModelBinding.ModelValidationState.Invalid ? "is-invalid" : "")" placeholder="e.g. 8" aria-describedby="SalaryGrade-error" />
                            <span id="SalaryGrade-error" asp-validation-for="SalaryGrade" class="invalid-feedback-custom"></span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end mt-4 gap-2">
                        <a asp-action="Index" class="btn btn-muted">Cancel</a>
                        <button type="submit" class="btn btn-brand">Create Position</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
