@model IEnumerable<EMS.Application.DTOs.Position.PositionDto>
@{
    ViewData["Title"] = "Positions";
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold text-dark m-0">Positions</h2>
        <p class="text-muted m-0">Manage job titles, base salaries, and salary grades</p>
    </div>
    @if (User.IsInRole("Admin") || User.IsInRole("HR"))
    {
        <a asp-action="Create" class="btn btn-brand">
            <i class="bi bi-plus-lg me-2"></i>New Position
        </a>
    }
</div>

<div class="card wfh-card overflow-hidden">
    <div class="card-body p-0">
        @if (Model == null || !Model.Any())
        {
            ViewData["EmptyStateIcon"] = "bi-briefcase";
            ViewData["EmptyStateHeading"] = "No Positions Found";
            ViewData["EmptyStateSubtext"] = "Get started by creating a new position above.";
            ViewData["EmptyStateActionUrl"] = Url.Action("Create");
            ViewData["EmptyStateActionText"] = "New Position";
            ViewData["EmptyStateActionRole"] = "Admin";
            <partial name="_EmptyState" />
        }
        else
        {
            <div class="table-responsive">
                <table class="wfh-table">
                    <caption class="visually-hidden">List of corporate positions including position title, base salary, salary grade, employee count, and action links</caption>
                    <thead>
                        <tr>
                            <th scope="col" class="ps-4">Title</th>
                            <th scope="col">Base Salary</th>
                            <th scope="col">Salary Grade</th>
                            <th scope="col" class="text-center">Employees</th>
                            <th scope="col" class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-semibold text-dark">@item.Title</td>
                                <td>@item.BaseSalary.ToString("C")</td>
                                <td>
                                    <span class="wfh-badge wfh-badge--resigned">Grade @item.SalaryGrade</span>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-info-subtle text-info rounded-pill px-3 py-1" style="font-size: 0.85rem;">@item.TotalEmployees</span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" title="Details" aria-label="View details for position @item.Title">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (User.IsInRole("Admin") || User.IsInRole("HR"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Edit" aria-label="Edit position @item.Title">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <button type="button" class="btn btn-sm btn-outline-danger" 
                                                    data-bs-toggle="modal" data-bs-target="#deleteModal" 
                                                    data-action="@Url.Action("Delete", "Position", new { id = item.Id })" 
                                                    data-name="@item.Title" 
                                                    data-warning="@(item.TotalEmployees > 0 ? $"This position is currently assigned to {item.TotalEmployees} active employee(s). You must assign them to a different position before deleting this position." : null)"
                                                    title="Delete" aria-label="Delete position @item.Title">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

<partial name="_DeleteModal" />
