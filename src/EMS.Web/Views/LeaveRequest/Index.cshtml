@model EMS.Application.Common.PagedResult<EMS.Application.DTOs.Leave.LeaveRequestDto>
@{
    ViewData["Title"] = "Leave Requests";
    Layout = "_Layout";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold text-dark m-0">Leave Management</h2>
        <p class="text-muted m-0">Review, submit, and approve leave requests</p>
    </div>
    @if (!User.IsInRole("Admin") && !User.IsInRole("HR") && !User.IsInRole("Manager"))
    {
        <a asp-action="Create" class="btn btn-brand">
            <i class="bi bi-calendar-plus me-2"></i>Apply for Leave
        </a>
    }
</div>

<div class="card wfh-card overflow-hidden">
    <div class="card-body p-0">
        @if (Model == null || !Model.Items.Any())
        {
            ViewData["EmptyStateIcon"] = "bi-calendar-check";
            ViewData["EmptyStateHeading"] = "No Leave Requests Found";
            ViewData["EmptyStateSubtext"] = "Active leave records will be displayed here.";
            ViewData["EmptyStateActionUrl"] = Url.Action("Create");
            ViewData["EmptyStateActionText"] = "Apply for Leave";
            ViewData["EmptyStateActionRole"] = "Employee";
            <partial name="_EmptyState" />
        }
        else
        {
            <div class="table-responsive">
                <table class="wfh-table">
                    <caption class="visually-hidden">List of leave applications including employee name, leave type, start/end dates, total days, approval status, and action controls</caption>
                    <thead>
                        <tr>
                            <th scope="col" class="ps-4">Employee</th>
                            <th scope="col">Type</th>
                            <th scope="col">Duration</th>
                            <th scope="col" class="text-center">Days</th>
                            <th scope="col" class="text-center">Status</th>
                            <th scope="col" class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td class="ps-4 fw-semibold text-dark">
                                    @item.EmployeeFullName
                                    <div class="text-muted small fw-normal">@item.EmployeeNumber</div>
                                </td>
                                <td>
                                    <span class="wfh-badge wfh-badge--resigned">@item.LeaveType</span>
                                </td>
                                <td class="text-muted">
                                    @item.StartDate.ToString("MMM dd, yyyy") - @item.EndDate.ToString("MMM dd, yyyy")
                                </td>
                                <td class="text-center">@item.TotalDays</td>
                                <td class="text-center">
                                    @switch (item.Status)
                                    {
                                        case LeaveStatus.Pending:
                                            <span class="wfh-badge wfh-badge--pending">Pending</span>
                                            break;
                                        case LeaveStatus.Approved:
                                            <span class="wfh-badge wfh-badge--approved">Approved</span>
                                            break;
                                        case LeaveStatus.Rejected:
                                            <span class="wfh-badge wfh-badge--rejected">Rejected</span>
                                            break;
                                        case LeaveStatus.Cancelled:
                                            <span class="wfh-badge wfh-badge--resigned">Cancelled</span>
                                            break;
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" title="Details" aria-label="View details for @item.EmployeeFullName's leave request">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (item.Status == LeaveStatus.Pending && !User.IsInRole("Admin") && !User.IsInRole("HR") && !User.IsInRole("Manager"))
                                        {
                                            <button type="button" class="btn btn-sm btn-outline-danger" 
                                                    data-bs-toggle="modal" data-bs-target="#deleteModal" 
                                                    data-action="@Url.Action("Cancel", "LeaveRequest", new { id = item.Id })" 
                                                    data-name="@item.EmployeeFullName's leave request" 
                                                    data-title="Cancel Leave Request" 
                                                    data-btn-text="Cancel Request" 
                                                    data-btn-class="btn-danger" 
                                                    data-icon-class="bi-x-circle"
                                                    title="Cancel" aria-label="Cancel leave request for @item.EmployeeFullName">
                                                <i class="bi bi-x-circle"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination Controls -->
            @if (Model.TotalPages > 1)
            {
                <div class="card-footer bg-white border-top-0 d-flex justify-content-between align-items-center px-4 py-3">
                    <div class="text-muted small">
                        Showing page @Model.PageNumber of @Model.TotalPages (Total: @Model.TotalCount items)
                    </div>
                    <nav aria-label="Page navigation">
                        <ul class="pagination pagination-sm m-0">
                            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                                <a class="page-link" href="@Url.Action("Index", new { pageNumber = Model.PageNumber - 1 })" aria-label="Previous page">
                                    <span aria-hidden="true">&laquo;</span>
                                </a>
                            </li>
                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                    <a class="page-link" href="@Url.Action("Index", new { pageNumber = i })" aria-label="Page @i">@i</a>
                                </li>
                            }
                            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                                <a class="page-link" href="@Url.Action("Index", new { pageNumber = Model.PageNumber + 1 })" aria-label="Next page">
                                    <span aria-hidden="true">&raquo;</span>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        }
    </div>
</div>

<partial name="_DeleteModal" />
