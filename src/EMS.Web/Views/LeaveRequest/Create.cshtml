@model EMS.Application.DTOs.Leave.LeaveRequestCreateDto
@{
    ViewData["Title"] = "Apply for Leave";
    Layout = "_Layout";
    ViewData["Breadcrumbs"] = new List<(string Label, string? Url)>
    {
        ("Leaves", Url.Action("Index", "LeaveRequest")),
        ("Apply for Leave", null)
    };
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card wfh-card">
            <div class="card-body p-5">
                <h3 class="fw-bold text-dark mb-4">Submit Leave Application</h3>

                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0" role="alert" style="border-radius: var(--radius-md);"></div>
                    <input type="hidden" asp-for="EmployeeId" />

                    <div class="mb-3">
                        <label asp-for="LeaveType" class="form-label-custom">Leave Type</label>
                        <select asp-for="LeaveType" class="form-select @(ViewData.ModelState.GetFieldValidationState("LeaveType") == Microsoft.AspNetCore.Mvc.ModelBinding.ModelValidationState.Invalid ? "is-invalid" : "")" aria-describedby="LeaveType-error">
                            <option value="1">Vacation</option>
                            <option value="2">Sick</option>
                            <option value="3">Emergency</option>
                            <option value="4">Unpaid</option>
                            <option value="5">Other</option>
                        </select>
                        <span id="LeaveType-error" asp-validation-for="LeaveType" class="invalid-feedback-custom"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="StartDate" class="form-label-custom">Start Date</label>
                            <input asp-for="StartDate" type="date" class="form-control @(ViewData.ModelState.GetFieldValidationState("StartDate") == Microsoft.AspNetCore.Mvc.ModelBinding.ModelValidationState.Invalid ? "is-invalid" : "")" aria-describedby="StartDate-error" />
                            <span id="StartDate-error" asp-validation-for="StartDate" class="invalid-feedback-custom"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="EndDate" class="form-label-custom">End Date</label>
                            <input asp-for="EndDate" type="date" class="form-control @(ViewData.ModelState.GetFieldValidationState("EndDate") == Microsoft.AspNetCore.Mvc.ModelBinding.ModelValidationState.Invalid ? "is-invalid" : "")" aria-describedby="EndDate-error" />
                            <span id="EndDate-error" asp-validation-for="EndDate" class="invalid-feedback-custom"></span>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Reason" class="form-label-custom">Reason for Leave</label>
                        <textarea asp-for="Reason" class="form-control @(ViewData.ModelState.GetFieldValidationState("Reason") == Microsoft.AspNetCore.Mvc.ModelBinding.ModelValidationState.Invalid ? "is-invalid" : "")" rows="4" placeholder="Brief explanation of your leave request..." aria-describedby="Reason-error"></textarea>
                        <span id="Reason-error" asp-validation-for="Reason" class="invalid-feedback-custom"></span>
                    </div>

                    <div class="d-flex justify-content-end mt-4 gap-2">
                        <a asp-action="Index" class="btn btn-muted">Cancel</a>
                        <button type="submit" class="btn btn-brand">Submit Application</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
