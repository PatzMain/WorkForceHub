@model EMS.Application.Common.PagedResult<EMS.Application.DTOs.Employee.EmployeeListDto>
@{
    ViewData["Title"] = "Employees";
    Layout = "_Layout";
    
    string GetSortArrow(string field)
    {
        if (ViewBag.SortBy == field)
        {
            return ViewBag.IsDescending ? " <i class='bi bi-arrow-down'></i>" : " <i class='bi bi-arrow-up'></i>";
        }
        return " <i class='bi bi-arrow-down-up text-muted opacity-50' style='font-size: 0.8rem;'></i>";
    }

    string GetSortDirection(string field)
    {
        if (ViewBag.SortBy == field)
        {
            return ViewBag.IsDescending ? "descending" : "ascending";
        }
        return "none";
    }
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="fw-bold text-dark m-0">Employees</h2>
        <p class="text-muted m-0">Directory of all corporate staff members</p>
    </div>
    @if (User.IsInRole("Admin") || User.IsInRole("HR"))
    {
        <a asp-action="Create" class="btn btn-brand">
            <i class="bi bi-person-plus me-2"></i>Add Employee
        </a>
    }
</div>

<!-- Search and Filter Bar -->
<div class="card wfh-card mb-4">
    <div class="card-body p-4">
        <form method="get" asp-action="Index" class="row g-3 align-items-end">
            <div class="col-md-3">
                <label class="form-label-custom">Search</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" name="search" class="form-control border-start-0" placeholder="Name, Email, Number..." value="@ViewBag.Search" />
                </div>
            </div>
            
            <div class="col-md-3">
                <label class="form-label-custom">Department</label>
                <select name="departmentId" class="form-select" asp-items="ViewBag.Departments">
                    <option value="">All Departments</option>
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label-custom">Position</label>
                <select name="positionId" class="form-select" asp-items="ViewBag.Positions">
                    <option value="">All Positions</option>
                </select>
            </div>

            <div class="col-md-2">
                <label class="form-label-custom">Status</label>
                <select name="status" class="form-select">
                    <option value="">All Statuses</option>
                    <option value="Active">Active</option>
                    <option value="OnLeave">On Leave</option>
                    <option value="Terminated">Terminated</option>
                    <option value="Resigned">Resigned</option>
                </select>
            </div>

            <div class="col-md-2 d-flex gap-2">
                <button type="submit" class="btn btn-muted w-100 py-2.5 font-weight-600">
                    Filter
                </button>
                <a asp-action="Index" class="btn btn-muted w-100 py-2.5" title="Reset Filters">
                    Reset
                </a>
            </div>
        </form>
    </div>
</div>

<!-- Employees List -->
<div class="card wfh-card overflow-hidden">
    <div class="card-body p-0">
        @if (Model == null || !Model.Items.Any())
        {
            ViewData["EmptyStateIcon"] = "bi-people";
            ViewData["EmptyStateHeading"] = "No Employees Found";
            ViewData["EmptyStateSubtext"] = "Try refining your search terms or filters.";
            ViewData["EmptyStateActionUrl"] = Url.Action("Create");
            ViewData["EmptyStateActionText"] = "Add Employee";
            ViewData["EmptyStateActionRole"] = "Admin";
            <partial name="_EmptyState" />
        }
        else
        {
            <div class="table-responsive">
                <table class="wfh-table">
                    <caption class="visually-hidden">List of employees showing profile, number, department, position, status, and action links</caption>
                    <thead>
                        <tr>
                            <th scope="col" aria-sort="@GetSortDirection("FullName")">
                                <a href="@Url.Action("Index", new { search = ViewBag.Search, departmentId = ViewBag.DepartmentId, positionId = ViewBag.PositionId, status = ViewBag.Status, sortBy = "FullName", isDescending = (ViewBag.SortBy == "FullName" && !ViewBag.IsDescending), pageNumber = Model.PageNumber })" class="text-decoration-none text-muted wfh-table-sort-header">
                                    Employee@Html.Raw(GetSortArrow("FullName"))
                                </a>
                            </th>
                            <th scope="col" aria-sort="@GetSortDirection("EmployeeNumber")">
                                <a href="@Url.Action("Index", new { search = ViewBag.Search, departmentId = ViewBag.DepartmentId, positionId = ViewBag.PositionId, status = ViewBag.Status, sortBy = "EmployeeNumber", isDescending = (ViewBag.SortBy == "EmployeeNumber" && !ViewBag.IsDescending), pageNumber = Model.PageNumber })" class="text-decoration-none text-muted wfh-table-sort-header">
                                    Employee #@Html.Raw(GetSortArrow("EmployeeNumber"))
                                </a>
                            </th>
                            <th scope="col">Department</th>
                            <th scope="col">Position</th>
                            <th scope="col" class="text-center">Status</th>
                            <th scope="col" class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="me-3">
                                            @if (!string.IsNullOrEmpty(item.ProfilePictureUrl))
                                            {
                                                <img src="@item.ProfilePictureUrl" alt="@item.FullName profile picture" class="rounded-circle shadow-sm" style="width: 40px; height: 40px; object-fit: cover;" loading="lazy" />
                                            }
                                            else
                                            {
                                                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold" style="width: 40px; height: 40px;" role="img" aria-label="Avatar for @item.FullName">
                                                    @item.FirstName[0]@item.LastName[0]
                                                </div>
                                            }
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark">@item.FullName</div>
                                            <div class="text-muted small">@item.Email</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="text-muted">@item.EmployeeNumber</td>
                                <td class="fw-semibold text-muted">@(item.DepartmentName ?? "N/A")</td>
                                <td class="text-muted">@(item.PositionTitle ?? "N/A")</td>
                                <td class="text-center">
                                    @switch (item.Status)
                                    {
                                        case EmploymentStatus.Active:
                                            <span class="wfh-badge wfh-badge--active">Active</span>
                                            break;
                                        case EmploymentStatus.OnLeave:
                                            <span class="wfh-badge wfh-badge--onleave">On Leave</span>
                                            break;
                                        case EmploymentStatus.Terminated:
                                            <span class="wfh-badge wfh-badge--terminated">Terminated</span>
                                            break;
                                        case EmploymentStatus.Resigned:
                                            <span class="wfh-badge wfh-badge--resigned">Resigned</span>
                                            break;
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary" title="Details" aria-label="View details for @item.FullName">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (User.IsInRole("Admin") || User.IsInRole("HR"))
                                        {
                                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary" title="Edit" aria-label="Edit @item.FullName">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <button type="button" class="btn btn-sm btn-outline-danger" 
                                                    data-bs-toggle="modal" data-bs-target="#deleteModal" 
                                                    data-action="@Url.Action("Delete", "Employee", new { id = item.Id })" 
                                                    data-name="@item.FullName" 
                                                    title="Delete" aria-label="Delete @item.FullName">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Pagination Controls -->
            @if (Model.TotalPages > 1)
            {
                <div class="card-footer bg-white border-top-0 d-flex justify-content-between align-items-center px-4 py-3">
                    <div class="text-muted small">
                        Showing page @Model.PageNumber of @Model.TotalPages (Total: @Model.TotalCount items)
                    </div>
                    <nav aria-label="Page navigation">
                        <ul class="pagination pagination-sm m-0">
                            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                                <a class="page-link" href="@Url.Action("Index", new { search = ViewBag.Search, departmentId = ViewBag.DepartmentId, positionId = ViewBag.PositionId, status = ViewBag.Status, sortBy = ViewBag.SortBy, isDescending = ViewBag.IsDescending, pageNumber = Model.PageNumber - 1 })" aria-label="Previous page">
                                    <span aria-hidden="true">&laquo;</span>
                                </a>
                            </li>
                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                    <a class="page-link" href="@Url.Action("Index", new { search = ViewBag.Search, departmentId = ViewBag.DepartmentId, positionId = ViewBag.PositionId, status = ViewBag.Status, sortBy = ViewBag.SortBy, isDescending = ViewBag.IsDescending, pageNumber = i })" aria-label="Page @i">@i</a>
                                </li>
                            }
                            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                                <a class="page-link" href="@Url.Action("Index", new { search = ViewBag.Search, departmentId = ViewBag.DepartmentId, positionId = ViewBag.PositionId, status = ViewBag.Status, sortBy = ViewBag.SortBy, isDescending = ViewBag.IsDescending, pageNumber = Model.PageNumber + 1 })" aria-label="Next page">
                                    <span aria-hidden="true">&raquo;</span>
                                </a>
                            </li>
                        </ul>
                    </nav>
                </div>
            }
        }
    </div>
</div>

<partial name="_DeleteModal" />
