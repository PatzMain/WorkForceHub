@model EMS.Application.DTOs.Employee.EmployeeDto
@{
    ViewData["Title"] = Model.FullName + " - Details";
    Layout = "_Layout";
    ViewData["Breadcrumbs"] = new List<(string Label, string? Url)>
    {
        ("Employees", Url.Action("Index", "Employee")),
        (Model.FullName, null)
    };
}

<div class="row">
    <!-- Profile Card (Left) -->
    <div class="col-lg-4 mb-4">
        <div class="card wfh-card text-center p-4">
            <div class="card-body">
                <div class="mb-4 d-flex justify-content-center">
                    @if (!string.IsNullOrEmpty(Model.ProfilePictureUrl))
                    {
                        <img src="@Model.ProfilePictureUrl" alt="@Model.FullName profile picture" class="rounded-circle shadow-sm" style="width: 140px; height: 140px; object-fit: cover;" />
                    }
                    else
                    {
                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold shadow-sm" style="width: 140px; height: 140px; font-size: 3rem;" role="img" aria-label="Avatar for @Model.FullName">
                            @Model.FirstName[0]@Model.LastName[0]
                        </div>
                    }
                </div>
                <h4 class="fw-bold text-dark mb-1">@Model.FullName</h4>
                <p class="text-muted small mb-3">@Model.EmployeeNumber</p>
                
                <div class="mb-4">
                    @switch (Model.Status)
                    {
                        case EmploymentStatus.Active:
                            <span class="wfh-badge wfh-badge--active">Active</span>
                            break;
                        case EmploymentStatus.OnLeave:
                            <span class="wfh-badge wfh-badge--onleave">On Leave</span>
                            break;
                        case EmploymentStatus.Terminated:
                            <span class="wfh-badge wfh-badge--terminated">Terminated</span>
                            break;
                        case EmploymentStatus.Resigned:
                            <span class="wfh-badge wfh-badge--resigned">Resigned</span>
                            break;
                    }
                </div>

                @if (User.IsInRole("Admin") || User.IsInRole("HR"))
                {
                    <div class="pt-2 d-grid gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-brand w-100">
                            <i class="bi bi-pencil me-1"></i>Edit Profile
                        </a>
                        <button type="button" class="btn btn-muted w-100" 
                                data-bs-toggle="modal" data-bs-target="#deleteModal" 
                                data-action="@Url.Action("Delete", "Employee", new { id = Model.Id })" 
                                data-name="@Model.FullName" 
                                aria-label="Delete @Model.FullName profile">
                            <i class="bi bi-trash me-1"></i>Delete Record
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Personal & Work Details (Right) -->
    <div class="col-lg-8 mb-4">
        <div class="card wfh-card">
            <div class="card-body p-5">
                <h4 class="fw-bold text-dark mb-4">Employee Information</h4>

                <div class="row g-4">
                    <div class="col-12">
                        <h5 class="fw-bold text-secondary text-uppercase small mb-1 border-bottom pb-2">Personal Details</h5>
                    </div>
                    
                    <div class="col-md-6">
                        <label class="form-label-custom d-block">Email Address</label>
                        <div class="fw-semibold text-dark">@Model.Email</div>
                    </div>
                    
                    <div class="col-md-6">
                        <label class="form-label-custom d-block">Phone Number</label>
                        <div class="fw-semibold text-dark">@(string.IsNullOrEmpty(Model.Phone) ? "N/A" : Model.Phone)</div>
                    </div>
                    
                    <div class="col-md-6">
                        <label class="form-label-custom d-block">Date of Birth</label>
                        <div class="fw-semibold text-dark">@Model.DateOfBirth.ToString("MMMM dd, yyyy")</div>
                    </div>
                    
                    <div class="col-md-6">
                        <label class="form-label-custom d-block">Gender</label>
                        <div class="fw-semibold text-dark">@Model.Gender</div>
                    </div>
                    
                    <div class="col-12">
                        <label class="form-label-custom d-block">Home Address</label>
                        <div class="fw-semibold text-dark">@(string.IsNullOrEmpty(Model.Address) ? "N/A" : Model.Address)</div>
                    </div>

                    <div class="col-12 mt-5">
                        <h5 class="fw-bold text-secondary text-uppercase small mb-1 border-bottom pb-2">Employment Details</h5>
                    </div>
                    
                    <div class="col-md-6">
                        <label class="form-label-custom d-block">Department</label>
                        <div class="fw-semibold text-dark">@(Model.DepartmentName ?? "Unassigned")</div>
                    </div>
                    
                    <div class="col-md-6">
                        <label class="form-label-custom d-block">Job Position</label>
                        <div class="fw-semibold text-dark">@(Model.PositionTitle ?? "Unassigned")</div>
                    </div>
                    
                    <div class="col-md-6">
                        <label class="form-label-custom d-block">Salary Details</label>
                        <div class="fw-semibold text-dark">@Model.BaseSalary.ToString("C")</div>
                    </div>
                    
                    <div class="col-md-6">
                        <label class="form-label-custom d-block">Date Joined</label>
                        <div class="fw-semibold text-dark">@Model.DateJoined.ToString("MMMM dd, yyyy")</div>
                    </div>
                    
                    @if (Model.DateTerminated.HasValue)
                    {
                        <div class="col-md-6">
                            <label class="form-label-custom d-block text-danger">Date Terminated</label>
                            <div class="fw-semibold text-danger">@Model.DateTerminated.Value.ToString("MMMM dd, yyyy")</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<partial name="_DeleteModal" />
